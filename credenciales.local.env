# ============================================================
# CREDENCIALES LOCALES — SISAPI (Docker Desktop)
# ============================================================
# Solo para pruebas en tu PC. NO usar en producción.
# ============================================================

# -----------------------------------------------------------
# CREDENCIALES POSTGRESQL
# (usadas por el contenedor postgres-sisapi-local)
# -----------------------------------------------------------
POSTGRES_USER=sisapi
POSTGRES_PASSWORD=LocalDev123$
POSTGRES_DB=sisapi

# -----------------------------------------------------------
# CONEXIÓN A BASE DE DATOS
# Host debe coincidir con el nombre del servicio PostgreSQL
# -----------------------------------------------------------
ConnectionStrings__CoreConnection=Host=postgres-sisapi;Port=5432;Database=sisapi;Username=sisapi;Password=LocalDev123$

# -----------------------------------------------------------
# CONFIGURACIÓN JWT
# -----------------------------------------------------------
JwtSettings__SecretKey=LocalDevSecretKeyForTesting123456789!
JwtSettings__Issuer=SisApi
JwtSettings__Audience=SisApiClient
JwtSettings__ExpiryInMinutes=60
JwtSettings__RefreshTokenExpiryInDays=7
JwtSettings__RememberMeRefreshTokenExpiryInDays=365

# -----------------------------------------------------------
# API KEY INTERNA (debe coincidir con webapinibu local)
# -----------------------------------------------------------
InternalApiKey=local-internal-api-key-dev

# -----------------------------------------------------------
# CORS — aceptar llamadas desde el frontend local y webapinibu local
# -----------------------------------------------------------
AllowedOrigins=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:8081

# -----------------------------------------------------------
# DOMINIO PARA COOKIES
# En local no se aplica dominio — dejar vacío para que use localhost
# -----------------------------------------------------------
CookieDomain=

# -----------------------------------------------------------
# JASPERSERVER (deshabilitado en local)
# -----------------------------------------------------------
# JasperServer__Url=
# JasperServer__Username=
# JasperServer__Password=

# -----------------------------------------------------------
# SUBDOMINIO Y PUERTO (referencia local)
# -----------------------------------------------------------
APP_DOMAIN=localhost
APP_PORT=8080

# -----------------------------------------------------------
# ENTORNO DE EJECUCIÓN
# Development habilita Swagger detallado y logs verbosos
# -----------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
