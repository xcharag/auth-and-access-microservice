# ============================================================
# SisApi Docker Stack - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
#
# For Coolify deployment, set these in the Coolify UI
# ============================================================

# ============================================
# DATABASE (External SQL Server)
# ============================================
# Host/IP of the existing SQL Server instance
DB_HOST=your-sql-server-ip-or-hostname
# SQL Server port (default: 1433)
DB_PORT=1433
# Database name
DB_NAME=sisapi
# Database user
DB_USER=sa
# Database password (REQUIRED - no default)
# IMPORTANT: Use a strong password (min 8 chars, uppercase, lowercase, number, special char)
DB_PASSWORD=YourStrong@Password123!

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Generate a strong secret key (at least 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=YourSuperSecretKeyForJWT2024!MustBeAtLeast32Characters
JWT_ISSUER=SisApi
JWT_AUDIENCE=SisApiClient
JWT_EXPIRY_MINUTES=10
JWT_REFRESH_EXPIRY_DAYS=7
JWT_REMEMBER_ME_EXPIRY_DAYS=365

# ============================================
# CORS & COOKIES CONFIGURATION
# ============================================
# Comma-separated list of allowed origins (no trailing slashes)
# Example: https://panel.yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=https://panel.yourdomain.com,https://localhost:5173

# Cookie domain for cross-subdomain auth (include leading dot)
# Example: .yourdomain.com
COOKIE_DOMAIN=.yourdomain.com

# ============================================
# APPLICATION DOMAIN (Traefik / Coolify routing)
# ============================================
# The domain that Traefik/Coolify will route to this service
APP_DOMAIN=api.yourdomain.com

# ============================================
# OPTIONAL: ASPNETCORE SETTINGS
# ============================================
ASPNETCORE_ENVIRONMENT=Production
