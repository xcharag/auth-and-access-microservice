# ============================================================
# SisApi Docker Stack - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
#
# For Coolify deployment, set these in the Coolify UI
# ============================================================

# ============================================
# SQL SERVER 2022 EXPRESS DATABASE
# ============================================
# IMPORTANT: Use a strong password (min 8 chars, uppercase, lowercase, number, special char)
DB_SA_PASSWORD=YourStrong@Password123!

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Generate a strong secret key (at least 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=1234
JWT_ISSUER=example.com
JWT_AUDIENCE=example.com
JWT_EXPIRY_MINUTES=10
JWT_REFRESH_EXPIRY_DAYS=7
JWT_REMEMBER_ME_EXPIRY_DAYS=365

# ============================================
# JASPER REPORTS SERVER 8.2.0
# ============================================
# Admin credentials for JasperServer
JASPER_USERNAME=jasperadmin
JASPER_PASSWORD=YourJasperAdmin@Password123!
JASPER_EMAIL=admin@yourdomain.com

# PostgreSQL database password for JasperServer (internal use)
JASPER_DB_PASSWORD=YourJasperDB@Password123!

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins (no trailing slashes)
# Example: https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ============================================
# OPTIONAL: ASPNETCORE SETTINGS
# ============================================
ASPNETCORE_ENVIRONMENT=Production
