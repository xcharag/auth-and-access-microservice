# ============================================================
# CREDENCIALES Y VARIABLES DE ENTORNO — SISAPI
# ============================================================
# IMPORTANTE: NO subir este archivo a repositorios públicos.
# Contiene contraseñas y claves secretas de producción.
# ============================================================

# -----------------------------------------------------------
# CREDENCIALES POSTGRESQL
# (usadas por el contenedor postgres-sisapi)
# -----------------------------------------------------------
POSTGRES_USER=sisapi
POSTGRES_PASSWORD=Nibu123$
POSTGRES_DB=sisapi

# -----------------------------------------------------------
# CONEXIÓN A BASE DE DATOS
# Host debe coincidir con el nombre del servicio PostgreSQL
# definido en docker-compose.production.yml (postgres-sisapi)
# -----------------------------------------------------------
ConnectionStrings__CoreConnection=Host=postgres-sisapi;Port=5432;Database=sisapi;Username=sisapi;Password=Nibu123$
DatabaseProvider=PostgreSQL

# -----------------------------------------------------------
# CONFIGURACIÓN JWT
# -----------------------------------------------------------
JwtSettings__SecretKey=ed3be647bb807604dce52dc1b1302d54a0341dce6c35d9c6d75c48514f92a15c
JwtSettings__Issuer=SisApi
JwtSettings__Audience=SisApiClient
JwtSettings__ExpiryInMinutes=10
JwtSettings__RefreshTokenExpiryInDays=7
JwtSettings__RememberMeRefreshTokenExpiryInDays=365

# -----------------------------------------------------------
# API KEY INTERNA (microservicio a microservicio)
# -----------------------------------------------------------
InternalApiKey=YUMzxQEP3kbQuAW6Tnvy7WSaVezAuNRcaUI49wxeWE5

# -----------------------------------------------------------
# CORS — orígenes permitidos separados por coma
# -----------------------------------------------------------
AllowedOrigins=https://wepainibu.upsa.edu.bo

# -----------------------------------------------------------
# DOMINIO PARA COOKIES (con punto inicial para cubrir subdominios)
# -----------------------------------------------------------
CookieDomain=.upsa.edu.bo

# -----------------------------------------------------------
# SUBDOMINIO Y PUERTO ASIGNADOS POR EL GATEWAY INSTITUCIONAL
# APP_DOMAIN → subdominio que el Gateway enruta a este contenedor
# APP_PORT   → puerto local expuesto (normalmente 8080)
# -----------------------------------------------------------
APP_DOMAIN=sisapi-nibu.upsa.edu.bo
APP_PORT=8080

# -----------------------------------------------------------
# ENTORNO DE EJECUCIÓN
# -----------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
