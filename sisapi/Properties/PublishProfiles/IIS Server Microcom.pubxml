<?xml version="1.0" encoding="utf-8"?>
<!--
This file is used by the publish/package process of your Web project. You can customize the behavior of this process
by editing this MSBuild file. In order to learn more about this please visit https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <WebPublishMethod>MSDeploy</WebPublishMethod>
        <ExcludeApp_Data>False</ExcludeApp_Data>

        <!-- URL del servidor Web Deploy (puerto 8172 para WMSVC) -->
        <MSDeployServiceURL>https://servidor01:8172/msdeploy.axd</MSDeployServiceURL>

        <!-- Ruta del sitio IIS en el servidor remoto -->
        <DeployIisAppPath>SisApi</DeployIisAppPath>

        <RemoteSitePhysicalPath/>
        <SkipExtraFilesOnServer>True</SkipExtraFilesOnServer>

        <!-- Método de publicación: WMSVC (Web Management Service) -->
        <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>

        <!-- Habilitar backups automáticos antes de publicar -->
        <EnableMSDeployBackup>True</EnableMSDeployBackup>

        <!-- Guardar contraseña (False = te pedirá credenciales cada vez) -->
        <_SavePWD>False</_SavePWD>

        <!-- Usuario de Windows para autenticación -->
        <UserName>servidor01\server</UserName>

        <!-- Permitir certificados SSL no confiables (para certificados autofirmados) -->
        <AllowUntrustedCertificate>True</AllowUntrustedCertificate>

        <SelfContained>false</SelfContained>
        <_IsPortable>true</_IsPortable>
    </PropertyGroup>
</Project>